# Video
*.mp4
*.avi
*.mov

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Python (for any Zenodo-related or helper scripts)
__pycache__/
*.pyc
.venv/
venv/

# Paper build artifacts (if you later add a LaTeX source)
*.aux
*.log
*.out
*.bbl
*.blg
*.synctex.gz
*.toc

